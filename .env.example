# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/smilepreview

# GCP
GCP_PROJECT_ID=your-project-id
GCS_BUCKET_NAME=smilepreview-images
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# AI Image Generation
GEMINI_API_KEY=your-gemini-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# Share Links
SHARE_BASE_URL=https://app.smilepreview.com
SHARE_TOKEN_EXPIRY_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
TRIAL_DAYS=3
TRIAL_DAILY_SIMULATION_LIMIT=1
FRONTEND_URL=https://app.smilepreview.com

# Docs (optional - leave empty for open access in dev, set for production gate)
DOCS_API_KEY=

# App
CORS_ORIGINS=http://localhost:3000,https://smilepreview.vercel.app
ENVIRONMENT=development
